{
  "mcpServers": {
    "godot-mcp-pro": {
      "command": "node",
      "args": [
        "/home/jerzy-wolf/workspace/foul-ward/FoulWard/MCPs/godot-mcp-pro-v1.6.1/server/build/index.js"
      ],
      "cwd": "/home/jerzy-wolf/workspace/foul-ward/FoulWard",
      "env": {
        "GODOT_MCP_PORT": "6505",
        "PATH": "/home/jerzy-wolf/.local/bin:/usr/bin:/usr/local/bin:/bin"
      }
    },
    "gdai-mcp-godot": {
      "command": "/home/jerzy-wolf/.local/bin/uv",
      "args": [
        "run",
        "/home/jerzy-wolf/workspace/foul-ward/FoulWard/addons/gdai-mcp-plugin-godot/gdai_mcp_server.py"
      ],
      "cwd": "/home/jerzy-wolf/workspace/foul-ward/FoulWard",
      "env": {
        "GDAI_MCP_SERVER_PORT": "3571",
        "GODOT_PROJECT_DIR": "/home/jerzy-wolf/workspace/foul-ward/FoulWard",
        "PATH": "/home/jerzy-wolf/.local/bin:/usr/bin:/usr/local/bin:/bin"
      }
    },
    "sequential-thinking": {
      "command": "node",
      "args": [
        "/home/jerzy-wolf/workspace/foul-ward/FoulWard/tools/mcp-support/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ],
      "cwd": "/home/jerzy-wolf/workspace/foul-ward/FoulWard/tools/mcp-support",
      "env": {
        "PATH": "/home/jerzy-wolf/.local/bin:/usr/bin:/usr/local/bin:/bin"
      }
    },
    "filesystem-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/jerzy-wolf/workspace"
      ],
      "env": {
        "PATH": "/home/jerzy-wolf/.local/bin:/usr/bin:/usr/local/bin:/bin"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "PATH": "/home/jerzy-wolf/.local/bin:/usr/bin:/usr/local/bin:/bin",
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "envFile": "${userHome}/.cursor/github-mcp.env"
    }
  }
