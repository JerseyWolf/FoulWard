[gd_resource type="Resource" script_class="CampaignConfig" format=3]
; campaign_main_50_days.tres — 50-day main campaign.
; Scaling: smoothstep HP/damage 1.0→3.0, linear gold 1.0→1.5, linear spawn 1.0→2.5.
; Formulas: t=(day-1)/49; hp/dmg=1+2*t*t*(3-2t); gold=1+0.5*t; spawn=1+1.5*t; starting_gold=1000+floor((day-1)*500/49).
; Wave counts: days 1-10 → 3, days 11-30 → 4, days 31-50 → 5.
; Faction rotation: no run >5 consecutive same faction. Territory-biased assignment.
; Mini-boss days: 10, 20, 30, 40. Final boss: day 50.


[ext_resource type="Script" path="res://scripts/resources/campaign_config.gd" id="1_campaignconfig"]
[ext_resource type="Script" path="res://scripts/resources/day_config.gd" id="2_dayconfig"]

