[ext_resource type="Script" path="res://scripts/resources/path_data.gd" id="3_path"]

[sub_resource type="Resource" id="lane_west"]
script = ExtResource("2_lane")
id = "lane_west"
display_name = "West Approach"
description = "Example lane — west sector."
florence_entry_tag = "leak_west"
threat_weight = 1.1
allowed_path_ids = PackedStringArray("path_01", "path_02")
tags = PackedStringArray("example", "west")

[sub_resource type="Resource" id="lane_mid"]
