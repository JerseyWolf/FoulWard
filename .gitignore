# Godot 4+ specific ignores
.godot/
/android/

# Optional local Godot editor binary (not part of the repo; set GODOT or PATH for smoke/tests)
Godot_v*-stable_linux.x86_64
Godot_v*-stable_mono_linux.x86_64
GodotSharp/

# Cross-platform / local OS & tool noise (safe on Windows + Ubuntu)
.DS_Store
Thumbs.db
*~
*.swp
*.swo
# Windows / editor temp next to native libs
*.TMP
**/bin/**/~*

# Python (addons, MCP tools, editor scripts)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Godot MCP Pro / GDAI MCP bridge sources live outside the repo (../foulward-mcp-servers/)
tools/mcp-support/node_modules/

# Local MCP secrets (never commit real tokens)
.cursor/github-mcp.env

# Cursor / local launch logs (not part of the game)
.launch-logs/

# Generated test / tool logs
reports/
tools/gdunit_out.txt
tools/gdunit_err.txt
tools/autotest_last_run.log
tools/autotest_last_run.err

# Local repository dump exports for LLM context
repo_dump_option_b_with_tests.txt

# Generated docs dump exports for LLM context
docs/DOCS_DUMP.md

# Empty / transient local dirs (not game code)
simbot_runs/

# Gen3D local artifacts — large PNG/GLB/session outputs (never commit; see docs/GEN3D_LOCAL_ARTIFACTS.md)
local/gen3d/

# Generated art (2D/3D pipeline drops) — not committed until production picks; see docs/GEN3D_LOCAL_ARTIFACTS.md
# Force-add only: art/generated/.gitkeep, art/gen3d_previews/.gitkeep, art/gen3d_candidates/.gitkeep
art/generated/
art/gen3d_previews/
art/gen3d_candidates/

# UniRig local temp (only applies if UniRig-repo lives under this workspace)
UniRig-repo/tmp/

# Godot C# build artifacts
.mono/
.godot/mono/
*.csproj.user
bin/
obj/
